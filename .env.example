# ===========================================================================
#  UXSense — environment configuration
#  Copy to `.env` and fill in. Never commit `.env`.
# ===========================================================================

# ---- Application ----
PROJECT_NAME=UXSense
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ---- Security / JWT ----
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_use_a_long_random_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- CORS (comma-separated) ----
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Database ----
POSTGRES_USER=uxsense
POSTGRES_PASSWORD=uxsense
POSTGRES_DB=uxsense
# Inside docker-compose the host is the service name `db`.
# For a local (non-docker) backend, use `localhost`.
DATABASE_URL=postgresql+asyncpg://uxsense:uxsense@db:5432/uxsense
SQL_ECHO=false

# ---- Redis / Celery ----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---- Rate limiting ----
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=10/minute

# ---- AI providers (set the one you use; verify current model IDs) ----
AI_PROVIDER=anthropic
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.2

# ---- Storage ----
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=storage/screenshots
S3_BUCKET=
S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ---- Browser automation ----
PLAYWRIGHT_HEADLESS=true
CRAWL_MAX_PAGES=15
CRAWL_TIMEOUT_MS=30000
VIEWPORT_WIDTH=1440
VIEWPORT_HEIGHT=900
